---
const { categorias } = Astro.props;
---

<div class="md:hidden w-full mb-10 z-20 relative">
  <div class="flex overflow-x-auto no-scrollbar gap-2 w-full bg-gray-100 dark:bg-[#111] p-1.5 rounded-sm border border-gray-200 dark:border-gray-800">
    {categorias.map((cat: any, index: number) => (
      <button class={`filter-btn shrink-0 flex items-center justify-center py-2.5 px-5 rounded-sm transition-all duration-300 ${index === 0 ? 'active active-' + cat.gradiente : 'text-gray-500 dark:text-gray-400'}`} data-filter={cat.id} data-color={cat.gradiente}>
        <span class="font-display font-bold text-[11px] uppercase tracking-widest text-center">{cat.nombre}</span>
      </button>
    ))}
  </div>
</div>

<div class="hidden md:flex w-full justify-center mb-14 z-20 relative">
  <div class="flex w-full bg-gray-100 dark:bg-[#111] p-1.5 rounded-sm border border-gray-200 dark:border-gray-800 transition-colors duration-700">
    {categorias.map((cat: any, index: number) => (
      <button class={`filter-btn flex-1 flex items-center justify-center py-3.5 lg:py-4 px-2 rounded-sm transition-all duration-300 hover:text-cr-dark dark:hover:text-white ${index === 0 ? 'active active-' + cat.gradiente : 'text-gray-500 dark:text-gray-400'}`} data-filter={cat.id} data-color={cat.gradiente}>
        <span class="font-display font-bold text-[9px] lg:text-[11px] uppercase tracking-widest leading-none text-center whitespace-nowrap overflow-hidden text-ellipsis">{cat.nombre}</span>
      </button>
    ))}
  </div>
</div>