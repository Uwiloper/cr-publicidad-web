---
const { trabajo } = Astro.props;
const gridImage = trabajo.galeria && trabajo.galeria.length > 0 ? trabajo.galeria[0] : trabajo.imagenPrincipal;

// LÓGICA DE GRILLA ASIMÉTRICA (Bento Grid)
const tamano = trabajo.tamano || 'cuadrado';

let sizeClasses = 'col-span-1 row-span-1'; // Default: cuadrado
if (tamano === 'horizontal') sizeClasses = 'col-span-2 row-span-1';
if (tamano === 'vertical') sizeClasses = 'col-span-1 row-span-2';
if (tamano === 'grande') sizeClasses = 'col-span-2 row-span-2';
---

<div 
  class={`portfolio-item group relative w-full h-full rounded-sm overflow-hidden bg-gray-100 dark:bg-[#111] cursor-pointer shadow-sm hover:shadow-2xl transition-all duration-500 transform border border-gray-200 dark:border-gray-800 opacity-0 translate-y-8 animate-fade-in-up ${sizeClasses}`} 
  data-json={JSON.stringify(trabajo)}
>
  
  <img src={gridImage} alt={trabajo.titulo} class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1500ms] group-hover:scale-105" loading="lazy" />
  
  <div class="absolute inset-0 bg-black/80 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-5 md:p-8 z-10">
    <span class="inline-block px-3 py-1 bg-[#cc4a04] text-white font-sans text-[9px] md:text-[10px] font-bold uppercase tracking-widest rounded-sm mb-3 self-start transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 delay-100">
      Ver Proyecto
    </span>
    <h3 class="font-display text-white text-lg md:text-xl lg:text-2xl font-bold leading-tight transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 delay-150 py-1">
      {trabajo.titulo}
    </h3>
  </div>
</div>

<style>
  /* Animación fluida de entrada */
  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }
</style>