---
---
<div id="project-modal" class="fixed inset-0 z-[100] hidden items-center justify-center opacity-0 transition-opacity duration-300 p-4 md:p-8">
  <div id="modal-backdrop" class="absolute inset-0 bg-black/80 backdrop-blur-sm cursor-pointer transition-opacity duration-300 z-0"></div>
  
  <div id="modal-box" class="custom-scrollbar relative bg-white dark:bg-[#0a0a0a] w-full max-w-6xl max-h-[90vh] overflow-y-auto rounded-sm shadow-2xl z-10 flex flex-col border border-gray-200 dark:border-gray-800 transform scale-95 transition-transform duration-300">
    
    <button id="modal-close-btn" class="absolute top-4 right-4 text-white/70 hover:text-white bg-black/40 hover:bg-[#cc4a04] p-2 rounded-sm transition-all z-50">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-0 w-full min-h-full">
      
      <div class="lg:col-span-7 p-6 md:p-10 flex flex-col gap-8 order-2 lg:order-1 border-t lg:border-t-0 lg:border-r border-gray-100 dark:border-gray-900">
        
        <div class="flex flex-wrap gap-4 items-center border-b border-gray-100 dark:border-gray-900 pb-5">
          <span id="modal-category" class="font-sans text-[11px] font-bold text-cr-dark dark:text-white bg-gray-100 dark:bg-[#111] border border-gray-200 dark:border-gray-800 px-3 py-1.5 rounded-sm uppercase tracking-wider">Proyecto</span>
          <span id="modal-client" class="font-sans text-[11px] md:text-xs font-medium text-gray-500 dark:text-gray-400"></span>
          <span id="modal-year" class="font-sans text-[11px] md:text-xs font-medium text-gray-500 dark:text-gray-400"></span>
        </div>

        <div id="modal-desc-container">
          <div class="flex items-center gap-4 mb-3">
            <div class="w-6 h-[2px] bg-[#cc4a04]"></div>
            <span class="font-mono text-[10px] md:text-xs tracking-[0.2em] text-gray-400 uppercase font-bold">Descripción</span>
          </div>
          <p id="modal-description" class="font-sans text-gray-700 dark:text-gray-300 text-sm md:text-base leading-relaxed"></p>
        </div>

        <div id="modal-services-container">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-6 h-[2px] bg-[#cc4a04]"></div>
            <span class="font-mono text-[10px] md:text-xs tracking-[0.2em] text-gray-400 uppercase font-bold">Trabajos Realizados</span>
          </div>
          <div id="modal-services-tags" class="flex flex-wrap gap-2 md:gap-3"></div>
        </div>

        <div id="modal-socials-container" class="border-t border-gray-100 dark:border-gray-900 pt-6 hidden mt-auto">
          <span class="font-mono text-[10px] md:text-xs tracking-[0.2em] text-gray-400 uppercase font-bold block mb-4">Explorar en nuestras Redes</span>
          <div id="modal-social-buttons" class="flex flex-wrap gap-3"></div>
        </div>

      </div>

      <div class="lg:col-span-5 flex flex-col order-1 lg:order-2 bg-[#050505]">
        
        <div class="relative w-full aspect-[4/3] lg:aspect-auto lg:h-[400px] overflow-hidden bg-black">
          <img id="modal-main-img" src="" alt="Proyecto" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500" />
          
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent/10 opacity-90 z-10 pointer-events-none"></div>
          
          <div class="absolute bottom-6 left-6 pr-6 z-20 pointer-events-none">
            <div id="modal-loc-container" class="flex items-center gap-2 bg-white/20 backdrop-blur-md px-3 py-1.5 rounded-sm w-fit mb-2 border border-white/10 hidden">
              <svg class="w-3.5 h-3.5 text-[#fb923c]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z"></path></svg>
              <span id="modal-location" class="font-sans text-[10px] font-bold text-white uppercase tracking-widest"></span>
            </div>
            <h2 id="modal-title" class="font-display text-2xl md:text-3xl font-bold text-white leading-none tracking-tight uppercase">---</h2>
          </div>
        </div>

        <div id="modal-thumbs-container" class="grid grid-cols-3 gap-0 w-full">
        </div>

      </div>

    </div>
  </div>
</div>

<script>
  // @ts-nocheck
  // Desactivar comprobaciones tipográficas de TS para manipulación de DOM directa en Astro
  
  const SocialIcons: any = {
    instagram: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>`,
    facebook: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
    tiktok: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 2.22-1.15 4.35-2.95 5.6-1.8 1.26-4.14 1.58-6.17.95-2.02-.62-3.6-2.04-4.38-3.95-.78-1.9-.59-4.15.53-5.88 1.11-1.74 3.02-2.84 5.06-2.94v4.02c-1.13.08-2.18.73-2.73 1.71-.56.97-.52 2.22.09 3.16.6.95 1.73 1.45 2.82 1.33 1.09-.12 2.02-.85 2.4-1.86.19-.51.27-1.07.26-1.62v-17.3Z"/></svg>`,
    youtube: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
    whatsapp: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>`
  };

  document.addEventListener('DOMContentLoaded', () => {

    const modal = document.getElementById('project-modal');
    const modalBox = document.getElementById('modal-box');
    const mainImg = document.getElementById('modal-main-img');
    const thumbsCont = document.getElementById('modal-thumbs-container');
    let timerId: number;
    let currentGallery: string[] = [];
    let currentIdx = 0;

    const changeImage = (idx: number) => {
      if (!mainImg || !currentGallery[idx]) return;
      currentIdx = idx;
      
      mainImg.style.opacity = '0.4';
      setTimeout(() => {
        mainImg.src = currentGallery[idx];
        mainImg.style.opacity = '1';
      }, 200);

      const thumbs = thumbsCont?.querySelectorAll('.thumb-btn');
      if (thumbs) {
        thumbs.forEach((t, i) => {
          if (i === idx) t.classList.add('border-[#cc4a04]');
          else t.classList.remove('border-[#cc4a04]');
        });
      }
    };

    const startTimer = () => {
      clearInterval(timerId);
      timerId = window.setInterval(() => {
        let next = (currentIdx + 1) % currentGallery.length;
        changePhotoManual(next);
      }, 4000);
    };

    const changePhotoManual = (idx: number) => {
      changeImage(idx);
      startTimer();
    };

    const openModal = (jsonString: string) => {
      const data = JSON.parse(jsonString);

      currentGallery = data.galeria && data.galeria.length > 0 ? data.galeria : [data.imagenPrincipal];
      currentIdx = 0;

      // === MANEJO DINÁMICO DE DATOS (Ocultar si no existen) ===

      // Título y Categoría
      const elTitle = document.getElementById('modal-title');
      if (elTitle) elTitle.textContent = data.titulo || 'Proyecto';
      const catName = document.querySelector(`.filter-btn[data-filter="${data.categoriaId}"] span`)?.textContent;
      const elCat = document.getElementById('modal-category');
      if (elCat) elCat.textContent = catName || "Proyecto";

      // Ubicación
      const elLocCont = document.getElementById('modal-loc-container');
      const elLoc = document.getElementById('modal-location');
      if (data.ubicacion) {
        if (elLocCont) elLocCont.classList.remove('hidden');
        if (elLoc) elLoc.textContent = data.ubicacion;
      } else {
        if (elLocCont) elLocCont.classList.add('hidden');
      }

      // Cliente
      const elClient = document.getElementById('modal-client');
      if (data.cliente) {
        if (elClient) {
          elClient.classList.remove('hidden');
          elClient.textContent = `Cliente: ${data.cliente}`;
        }
      } else {
        if (elClient) elClient.classList.add('hidden');
      }

      // Año
      const elYear = document.getElementById('modal-year');
      if (data.anio) {
        if (elYear) {
          elYear.classList.remove('hidden');
          elYear.textContent = `Año: ${data.anio}`;
        }
      } else {
        if (elYear) elYear.classList.add('hidden');
      }

      // Descripción
      const descCont = document.getElementById('modal-desc-container');
      const elDesc = document.getElementById('modal-description');
      if (data.descripcion) {
        if (descCont) descCont.classList.remove('hidden');
        if (elDesc) elDesc.textContent = data.descripcion;
      } else {
        if (descCont) descCont.classList.add('hidden');
      }

      // Tags de Servicios
      const tagsContParent = document.getElementById('modal-services-container');
      const tagsCont = document.getElementById('modal-services-tags');
      if (data.servicios && data.servicios.length > 0) {
        if (tagsContParent) tagsContParent.classList.remove('hidden');
        if (tagsCont) {
          tagsCont.innerHTML = data.servicios.map((s: any) => {
            const colorClass = s.color === 'azul' ? 'tag-azul' : 'tag-naranja';
            return `<span class="${colorClass} px-3 py-1.5 rounded-sm text-[10px] md:text-xs font-bold uppercase tracking-widest transition-transform hover:-translate-y-0.5">${s.texto}</span>`;
          }).join('');
        }
      } else {
        if (tagsContParent) tagsContParent.classList.add('hidden');
      }

      // Redes Sociales
      const socCont = document.getElementById('modal-socials-container');
      const socBtns = document.getElementById('modal-social-buttons');
      if (data.redes && Object.keys(data.redes).length > 0) {
        if (socCont) socCont.classList.remove('hidden');
        if (socBtns) {
          socBtns.innerHTML = Object.entries(data.redes).map(([name, url]) => {
            const icon = SocialIcons[name.toLowerCase()] || '';
            return `<a href="${url}" target="_blank" class="social-btn social-${name.toLowerCase()}">${icon} ${name}</a>`;
          }).join('');
        }
      } else {
        if (socCont) socCont.classList.add('hidden');
      }

      // Renderizar Miniaturas (Thumbnails)
      if (thumbsCont) {
        thumbsCont.innerHTML = currentGallery.map((img: string, i: number) => `
          <button class="thumb-btn border-t-4 border-transparent aspect-video bg-[#111] overflow-hidden relative group transition-all duration-300" data-idx="${i}">
            <div class="absolute inset-0 bg-black/40 group-hover:bg-transparent transition-colors z-10"></div>
            <img src="${img}" class="w-full h-full object-cover" />
          </button>
        `).join('');

        thumbsCont.querySelectorAll('.thumb-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const idx = parseInt((e.currentTarget as HTMLElement).getAttribute('data-idx') || '0');
            changePhotoManual(idx);
          });
        });
      }

      // Cargar primera imagen y arrancar reloj
      changeImage(0);
      startTimer();

      // Mostrar Modal
      document.body.style.overflow = 'hidden';
      if (modal) {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        setTimeout(() => {
          modal.style.opacity = '1';
          if (modalBox) {
            modalBox.style.transform = 'scale(1)';
            modalBox.scrollTop = 0; 
          }
        }, 10);
      }
    };

    const closeModal = () => {
      if (modal) modal.style.opacity = '0';
      if (modalBox) modalBox.style.transform = 'scale(0.95)';
      document.body.style.overflow = '';
      clearInterval(timerId);
      setTimeout(() => {
        if (modal) {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
        }
      }, 300);
    };

    // Asignar Eventos Clic
    const updateGridListeners = () => {
        document.querySelectorAll('.portfolio-item').forEach(item => {
            // Remueve listeners antiguos si los hay para evitar doble ejecución
            item.replaceWith(item.cloneNode(true));
        });
        
        document.querySelectorAll('.portfolio-item').forEach(item => {
            item.addEventListener('click', (e) => {
                const jsonStr = (e.currentTarget as HTMLElement).getAttribute('data-json');
                if (jsonStr) openModal(jsonStr);
            });
        });
    };
    
    updateGridListeners();
    // En caso de que se filtren o cambien, asegura que los botones siempre abran el modal
    document.querySelectorAll('.filter-btn').forEach(btn => btn.addEventListener('click', () => setTimeout(updateGridListeners, 350)));


    const btnClose = document.getElementById('modal-close-btn');
    if (btnClose) btnClose.addEventListener('click', closeModal);

    const backdropObj = document.getElementById('modal-backdrop');
    if (backdropObj) backdropObj.addEventListener('click', closeModal);

    document.addEventListener('keydown', (e) => { 
      if (e.key === 'Escape') closeModal(); 
    });

  });
</script>