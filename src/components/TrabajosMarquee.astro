---
import portafolioData from '../data/portafolio.json';

const trabajos = portafolioData.trabajos || [];
// Multiplicamos para asegurar el scroll infinito sin huecos
const filaInfinita = [...trabajos, ...trabajos, ...trabajos, ...trabajos];
---

<section class="w-full bg-white dark:bg-[#050505] py-24 transition-colors duration-700 overflow-hidden relative border-t border-gray-100 dark:border-gray-900">
  
  <div class="max-w-[1200px] mx-auto px-6 lg:px-8 mb-16 observer-blur opacity-0 translate-y-12 blur-md transition-all duration-1000 ease-out">
    <h3 class="font-mono text-[10px] md:text-xs tracking-[0.3em] text-[#cc4a04] uppercase font-bold mb-4">
      Casos Destacados
    </h3>
    <h2 class="font-display font-extrabold text-3xl md:text-4xl text-cr-dark dark:text-white uppercase tracking-tight">
      Nuestra Trayectoria
    </h2>
  </div>

  <div class="relative w-full flex overflow-hidden marquee-container">
    
    <div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-white dark:from-[#050505] to-transparent z-20 pointer-events-none"></div>
    <div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-white dark:dark:from-[#050505] to-transparent z-20 pointer-events-none"></div>

    <div class="flex w-max animate-marquee gap-6 px-6">
      {filaInfinita.map((trabajo: any) => (
        <a 
          href={`/portafolio?proyecto=${trabajo.id}`} 
          class="relative w-[280px] md:w-[350px] aspect-[4/3] rounded-sm overflow-hidden bg-gray-100 dark:bg-[#111] shrink-0 border border-gray-200 dark:border-gray-800 cursor-pointer group/card shadow-sm hover:shadow-2xl transition-all duration-500 hover:-translate-y-2"
        >
          <img 
            src={trabajo.imagenPrincipal} 
            alt={trabajo.titulo} 
            class="w-full h-full object-cover transition-transform duration-[1500ms] group-hover/card:scale-110" 
            loading="lazy" 
          />
          
          <div class="absolute inset-0 bg-black/70 opacity-0 group-hover/card:opacity-100 transition-opacity duration-500 flex flex-col justify-end p-8">
            <span class="font-mono text-[9px] font-bold text-[#cc4a04] uppercase tracking-[0.3em] mb-2">VER PROYECTO</span>
            <h3 class="font-display text-white text-xl font-bold leading-tight">
              {trabajo.titulo}
            </h3>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  /* Degradados laterales usando mask-image (El método profesional) */
  .marquee-container {
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  
  .animate-marquee {
    animation: marquee 40s linear infinite;
  }
  
  .marquee-container:hover .animate-marquee {
    animation-play-state: paused;
  }
</style>

<script>
  // Animación de entrada suave
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-12', 'blur-md');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.observer-blur').forEach(el => observer.observe(el));
  });
</script>