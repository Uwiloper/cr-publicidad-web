---
import globalData from '../data/global.json';

const waData = globalData.whatsapp;
const mensajeEncodeado = encodeURIComponent(waData.mensajeDefecto);
---

<div class="fixed bottom-6 right-6 md:bottom-8 md:right-8 z-50 flex flex-col items-end transition-all duration-500 ease-in-out">
  
  <div id="wa-modal" class="opacity-0 translate-y-8 scale-95 pointer-events-none transition-all duration-300 ease-out mb-4 md:mb-5 bg-white dark:bg-[#111] border border-gray-200 dark:border-gray-800 rounded-xl shadow-2xl w-[260px] md:w-[280px] overflow-hidden origin-bottom-right">
    
    <div class="bg-[#25D366] px-5 py-4 text-white relative overflow-hidden">
      <svg class="absolute -right-4 -bottom-4 w-24 h-24 text-white/20 rotate-12" fill="currentColor" viewBox="0 0 24 24"><path d="M12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
      <h3 class="font-display font-bold text-base relative z-10">Conversemos</h3>
      <p class="font-sans text-xs opacity-90 relative z-10 mt-1">Resolveremos tus dudas</p>
    </div>
    
    <div class="flex flex-col p-2 gap-1">
      {waData.contactos.map((contacto: any) => (
        <a 
          href={`https://wa.me/${contacto.numero}?text=${mensajeEncodeado}`} 
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-between p-3 hover:bg-gray-50 dark:hover:bg-[#1a1a1a] rounded-lg transition-all duration-300 group hover:translate-x-1"
        >
          <div class="flex flex-col">
            <span class="font-sans font-bold text-xs md:text-sm text-gray-800 dark:text-gray-200 group-hover:text-[#25D366] transition-colors">
              {contacto.nombre}
            </span>
            <span class="font-mono text-[10px] md:text-[11px] text-gray-500 mt-0.5">
              {contacto.mostrarComo}
            </span>
          </div>
          <svg class="w-4 h-4 md:w-5 md:h-5 text-gray-400 group-hover:text-[#25D366] transition-all duration-300 transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </a>
      ))}
    </div>
  </div>

  <button id="wa-btn" class="relative group flex items-center justify-center w-14 h-14 md:w-16 md:h-16 bg-[#25D366] text-white rounded-full shadow-lg shadow-[#25D366]/40 transition-all duration-300 ease-out hover:scale-110 hover:-translate-y-1 hover:shadow-xl hover:shadow-[#25D366]/50 hover:bg-[#20bd5c] focus:outline-none">
    
    <span class="absolute inset-0 rounded-full bg-[#25D366] animate-ping opacity-30 group-hover:opacity-0 transition-opacity duration-300" style="animation-duration: 2.5s;"></span>
    
    <svg class="w-8 h-8 md:w-9 md:h-9 relative z-10 transition-transform duration-300 group-hover:rotate-[8deg]" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
    </svg>
  </button>
  
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('wa-btn');
    const modal = document.getElementById('wa-modal');
    let isOpen = false;

    if (btn && modal) {
      btn.addEventListener('click', () => {
        isOpen = !isOpen;
        if (isOpen) {
          // Animación de entrada (Pop y Fade In)
          modal.classList.remove('opacity-0', 'translate-y-8', 'scale-95', 'pointer-events-none');
          modal.classList.add('opacity-100', 'translate-y-0', 'scale-100', 'pointer-events-auto');
        } else {
          // Animación de salida (Cierre suave)
          modal.classList.add('opacity-0', 'translate-y-8', 'scale-95', 'pointer-events-none');
          modal.classList.remove('opacity-100', 'translate-y-0', 'scale-100', 'pointer-events-auto');
        }
      });

      // Cierra el modal si el usuario hace clic en cualquier parte fuera de él
      document.addEventListener('click', (e) => {
        if (isOpen && !btn.contains(e.target as Node) && !modal.contains(e.target as Node)) {
          isOpen = false;
          modal.classList.add('opacity-0', 'translate-y-8', 'scale-95', 'pointer-events-none');
          modal.classList.remove('opacity-100', 'translate-y-0', 'scale-100', 'pointer-events-auto');
        }
      });
    }
  });
</script>