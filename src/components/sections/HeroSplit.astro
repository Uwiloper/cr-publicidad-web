---
import inicioData from '../../data/inicio.json';
import portafolioData from '../../data/portafolio.json';

const diapositivas = inicioData?.hero?.diapositivas || [];
const primeraDiapositiva = diapositivas[0] || {};
const trabajos = portafolioData?.trabajos || [];
// Extraemos las imágenes del portafolio
const fotosBase = trabajos.map((t: any) => t.imagenPrincipal).filter(Boolean);

// Bucle infinito: Multiplicamos para tener un arreglo largo y dividimos exactamente en 2 mitades
const buildHorizontalLoop = (arr: any[]) => {
  if (!arr || arr.length === 0) return [];
  let track = [...arr];
  while (track.length < 15) { track = [...track, ...arr]; }
  return [...track, ...track]; 
};

const galeriaInfinita = buildHorizontalLoop(fotosBase);

const getBtnGradient = (tipo?: string) => {
  if (tipo === 'naranja') return 'from-[#cc4a04] to-[#fb923c] shadow-orange-500/25';
  return 'from-[#173154] to-[#3b82f6] shadow-blue-500/25';
};

const diapositivasJSON = JSON.stringify(diapositivas);
---

<section class="relative w-full h-[100dvh] min-h-[700px] md:min-h-[800px] bg-[#f8f9fa] dark:bg-[#050505] transition-colors duration-700 flex flex-col items-center pt-16 md:pt-20 overflow-hidden">
  
  <div id="hero-text-container" data-slides={diapositivasJSON} class="relative z-30 flex flex-col items-center justify-center text-center px-4 w-full max-w-[90vw] md:max-w-6xl mb-4 md:mb-6 transition-all duration-500 transform translate-y-0 opacity-100 min-h-[220px] md:min-h-[260px]">
    
    <div id="hero-tag-container" class={`mb-3 md:mb-4 ${!primeraDiapositiva?.etiqueta ? 'hidden' : ''}`}>
      <span id="hero-tag" class="font-sans text-[10px] md:text-[12px] font-bold uppercase tracking-[0.25em] text-[#cc4a04] dark:text-[#fb923c]">
        {primeraDiapositiva.etiqueta}
      </span>
    </div>
    
    <h1 class="font-display font-extrabold uppercase leading-[1.05] tracking-tight flex flex-row flex-wrap items-center justify-center gap-x-3 md:gap-x-5 gap-y-2 w-full">
      <span id="hero-title-orange" class={`bg-gradient-to-r from-[#cc4a04] to-[#fb923c] text-transparent bg-clip-text text-[clamp(1.5rem,4vw,5rem)] whitespace-nowrap pb-1 ${!primeraDiapositiva?.tituloNaranja ? 'hidden' : ''}`}>
        {primeraDiapositiva.tituloNaranja}
      </span>
      <span id="hero-title-normal" class={`text-gray-900 dark:text-white text-[clamp(1.5rem,4vw,5rem)] whitespace-nowrap ${!primeraDiapositiva?.tituloNormal ? 'hidden' : ''}`}>
        {primeraDiapositiva.tituloNormal}
      </span>
      <span id="hero-title-blue" class={`bg-gradient-to-r from-[#173154] to-[#3b82f6] text-transparent bg-clip-text text-[clamp(1.5rem,4vw,5rem)] whitespace-nowrap pb-1 ${!primeraDiapositiva?.tituloAzul ? 'hidden' : ''}`}>
        {primeraDiapositiva.tituloAzul}
      </span>
    </h1>
    
    <p id="hero-desc" class={`font-sans text-gray-600 dark:text-gray-400 mt-3 md:mt-5 text-xs sm:text-sm md:text-base font-medium max-w-3xl mx-auto leading-relaxed px-2 ${!primeraDiapositiva?.descripcion ? 'hidden' : ''}`}>
      {primeraDiapositiva.descripcion}
    </p>

    <div class="mt-5 md:mt-8 flex flex-col sm:flex-row items-center justify-center gap-4 w-full px-6">
      <a id="hero-btn-1" href={primeraDiapositiva?.btnPrincipal?.ruta || '#'} class={`group relative text-white font-sans font-bold text-[10px] sm:text-[12px] tracking-widest py-3.5 md:py-4 px-10 transition-all duration-300 hover:scale-105 shadow-xl flex items-center justify-center gap-3 w-full sm:w-auto rounded-none bg-gradient-to-r ${getBtnGradient(primeraDiapositiva?.btnPrincipal?.gradiente || 'naranja')} ${!primeraDiapositiva?.btnPrincipal?.active ? 'hidden' : ''}`}>
        <span id="hero-btn-1-text">{primeraDiapositiva?.btnPrincipal?.texto}</span>
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
      </a>
    
      <a id="hero-btn-2" href={primeraDiapositiva?.btnSecundario?.ruta || '#'} class={`group bg-white/40 dark:bg-[#0a0a0a]/40 backdrop-blur-md border border-gray-300 dark:border-gray-700 hover:border-gray-900 dark:hover:border-white text-gray-900 dark:text-white font-sans font-bold text-[10px] sm:text-[12px] tracking-widest py-3.5 md:py-4 px-10 transition-all duration-300 hover:bg-gray-100 dark:hover:bg-white/5 flex items-center justify-center gap-3 rounded-none w-full sm:w-auto ${!primeraDiapositiva?.btnSecundario?.active ? 'hidden' : ''}`}>
        <span id="hero-btn-2-text">{primeraDiapositiva?.btnSecundario?.texto}</span>
      </a>
    </div>
  </div>

  <div id="carousel-container" class="relative w-full flex-1 max-h-[500px] flex items-center justify-center z-10 cursor-grab active:cursor-grabbing select-none" style="perspective: 1200px;">
    
    <div id="swipe-hint" class="absolute inset-0 z-40 flex items-center justify-center pointer-events-none transition-opacity duration-700 opacity-100">
      <div class="bg-black/60 dark:bg-white/10 backdrop-blur-md px-6 py-3 rounded-full flex items-center gap-3 shadow-2xl border border-white/20 animate-swipe-horizontal">
        <svg class="block md:hidden w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11" />
        </svg>
        <svg class="hidden md:block w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" />
        </svg>
        <span class="text-white font-mono text-[10px] uppercase tracking-widest font-bold">Desliza para explorar</span>
      </div>
    </div>

    <div class="absolute -inset-y-24 md:-inset-y-40 left-0 w-24 md:w-[26rem] bg-gradient-to-r from-[#f8f9fa] via-[#f8f9fa]/95 to-transparent dark:from-[#050505] dark:via-[#050505]/95 z-20 pointer-events-none"></div>
    <div class="absolute -inset-y-24 md:-inset-y-40 right-0 w-24 md:w-[26rem] bg-gradient-to-l from-[#f8f9fa] via-[#f8f9fa]/95 to-transparent dark:from-[#050505] dark:via-[#050505]/95 z-20 pointer-events-none"></div>

    <div id="marquee-track" class="flex w-max items-center will-change-transform" style="transform-style: preserve-3d;">
      {galeriaInfinita.map((img: string, index: number) => {
        const realIndex = index % fotosBase.length;
        return (
        <div class="cinta-wrapper relative w-[180px] sm:w-[240px] md:w-[280px] lg:w-[320px] h-[260px] sm:h-[340px] md:h-[400px] lg:h-[460px] flex-shrink-0" data-idx={realIndex} style="transform-style: preserve-3d;">
          <div class="cinta-3d-item absolute inset-0 rounded-none overflow-hidden bg-gray-200 dark:bg-gray-800 shadow-2xl pointer-events-none border border-black/5 dark:border-white/10">
            <img src={img} alt="Proyecto" class="absolute inset-0 w-full h-full object-cover pointer-events-none" />
            <div class="cinta-overlay absolute inset-0 bg-black/0 transition-colors pointer-events-none"></div>
          </div>
        </div>
      )})}
    </div>
    
    <div class="absolute bottom-[-10px] md:bottom-2 left-0 w-full flex justify-center items-center gap-1.5 md:gap-2.5 z-30 pagination-dots">
      {fotosBase.map((_, idx) => (
        <div class={`dot h-2 rounded-full transition-all duration-300 ease-out shadow-sm ${idx === 0 ? 'w-6 md:w-8 bg-[#cc4a04]' : 'w-2 bg-gray-300 dark:bg-gray-700'}`} data-dot-idx={idx}></div>
      ))}
    </div>
  </div>

  <div class="absolute bottom-0 left-0 w-full h-32 md:h-56 bg-gradient-to-t from-[#f8f9fa] dark:from-[#050505] to-transparent z-20 pointer-events-none"></div>
  
  <div class="absolute bottom-4 left-1/2 -translate-x-1/2 z-30 flex flex-col items-center pointer-events-none text-gray-500 dark:text-gray-400">
    <span class="text-[9px] md:text-[10px] font-bold uppercase tracking-[0.2em] mb-1">Scroll</span>
    <svg class="w-4 h-4 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>

</section>

<style is:global>
  @keyframes swipeHorizontal {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(-30px); }
  }
  .animate-swipe-horizontal {
    animation: swipeHorizontal 2.5s ease-in-out infinite;
  }
</style>

<script>
  // @ts-nocheck
  document.addEventListener('DOMContentLoaded', () => {
    
    // --- 1. LÓGICA DE ROTACIÓN DE TEXTOS ---
    const textContainer = document.getElementById('hero-text-container');
    if (textContainer && textContainer.dataset.slides) {
      const slides = JSON.parse(textContainer.dataset.slides);
      if (slides.length > 1) {
        let currentSlideIdx = 0;
        
        const elTagBox = document.getElementById('hero-tag-container');
        const elTag = document.getElementById('hero-tag');
        const elTitNaranja = document.getElementById('hero-title-orange');
        const elTitNormal = document.getElementById('hero-title-normal');
        const elTitAzul = document.getElementById('hero-title-blue');
        const elDesc = document.getElementById('hero-desc');
        const elBtn1 = document.getElementById('hero-btn-1');
        const elBtn1Text = document.getElementById('hero-btn-1-text');
        const elBtn2 = document.getElementById('hero-btn-2');
        const elBtn2Text = document.getElementById('hero-btn-2-text');

        setInterval(() => {
          textContainer.classList.remove('opacity-100', 'translate-y-0');
          textContainer.classList.add('opacity-0', '-translate-y-6');
          
          setTimeout(() => {
            currentSlideIdx = (currentSlideIdx + 1) % slides.length;
            const slide = slides[currentSlideIdx];

            if (slide.etiqueta) { elTagBox.classList.remove('hidden'); elTag.textContent = slide.etiqueta; } 
            else { elTagBox.classList.add('hidden'); }

            if (slide.tituloNaranja) { elTitNaranja.classList.remove('hidden'); elTitNaranja.textContent = slide.tituloNaranja; } 
            else { elTitNaranja.classList.add('hidden'); }
            
            if (slide.tituloNormal) { elTitNormal.classList.remove('hidden'); elTitNormal.textContent = slide.tituloNormal; } 
            else { elTitNormal.classList.add('hidden'); }
            
            if (slide.tituloAzul) { elTitAzul.classList.remove('hidden'); elTitAzul.textContent = slide.tituloAzul; } 
            else { elTitAzul.classList.add('hidden'); }

            if (slide.descripcion) { elDesc.classList.remove('hidden'); elDesc.textContent = slide.descripcion; } 
            else { elDesc.classList.add('hidden'); }

            if (slide.btnPrincipal?.active) {
              elBtn1.classList.remove('hidden');
              elBtn1.href = slide.btnPrincipal.ruta || '#';
              elBtn1Text.textContent = slide.btnPrincipal.texto;
            } else { elBtn1.classList.add('hidden'); }

            if (slide.btnSecundario?.active) {
              elBtn2.classList.remove('hidden');
              elBtn2.href = slide.btnSecundario.ruta || '#';
              elBtn2Text.textContent = slide.btnSecundario.texto;
            } else { elBtn2.classList.add('hidden'); }

            textContainer.style.transition = 'none';
            textContainer.classList.remove('-translate-y-6');
            textContainer.classList.add('translate-y-6');
            
            void textContainer.offsetHeight;

            textContainer.style.transition = '';
            textContainer.classList.remove('opacity-0', 'translate-y-6');
            textContainer.classList.add('opacity-100', 'translate-y-0');
            
          }, 500);
        }, 7000);
      }
    }

    // --- 2. LÓGICA DEL CARRUSEL PANORAMA ---
    const container = document.getElementById('carousel-container');
    const track = document.getElementById('marquee-track');
    const wrappers = document.querySelectorAll('.cinta-wrapper');
    const dots = document.querySelectorAll('.dot');
    const swipeHint = document.getElementById('swipe-hint');
    
    if (!container || !track || !wrappers.length) return;

    let isDragging = false;
    let startX = 0;
    let currentScroll = 0; 
    let velocity = 1.0; 

    const totalItems = wrappers.length;
    const halfItems = totalItems / 2;
    let itemWidth = wrappers[0].offsetWidth;
    let seamlessJumpBoundary = itemWidth * halfItems;

    window.addEventListener('resize', () => {
      itemWidth = wrappers[0].offsetWidth;
      seamlessJumpBoundary = itemWidth * halfItems;
    });

    const hideSwipeHint = () => {
      if (swipeHint && swipeHint.style.opacity !== '0') {
        swipeHint.style.opacity = '0';
        setTimeout(() => swipeHint.remove(), 700); 
      }
    };

    const dragStart = (e) => {
      isDragging = true;
      hideSwipeHint(); 
      container.classList.remove('cursor-grab');
      container.classList.add('cursor-grabbing');
      startX = (e.type.includes('mouse') ? e.pageX : e.touches[0].clientX) - currentScroll;
    };

    const dragEnd = () => {
      isDragging = false;
      container.classList.add('cursor-grab');
      container.classList.remove('cursor-grabbing');
    };

    const dragMove = (e) => {
      if (!isDragging) return;
      e.preventDefault();
      const x = e.type.includes('mouse') ? e.pageX : e.touches[0].clientX;
      currentScroll = x - startX;
    };

    container.addEventListener('mousedown', dragStart);
    container.addEventListener('mouseup', dragEnd);
    container.addEventListener('mouseleave', dragEnd);
    container.addEventListener('mousemove', dragMove);

    container.addEventListener('touchstart', dragStart, { passive: true });
    container.addEventListener('touchend', dragEnd);
    container.addEventListener('touchmove', dragMove, { passive: false });

    const update3DCarousel = () => {
      if (!isDragging) {
        currentScroll -= velocity;
      }

      if (currentScroll <= -seamlessJumpBoundary) {
        currentScroll += seamlessJumpBoundary;
        if(isDragging) startX -= seamlessJumpBoundary; 
      } else if (currentScroll > 0) {
        currentScroll -= seamlessJumpBoundary;
        if(isDragging) startX += seamlessJumpBoundary;
      }

      track.style.transform = `translate3d(${currentScroll}px, 0, 0)`;

      const centerX = window.innerWidth / 2;
      let minDistance = Infinity;
      let activeIndex = 0;
      
      const isMobile = window.innerWidth < 768;
      
      const zMultiplier = isMobile ? 150 : 250; 
      const zOffset = isMobile ? -50 : -120; 
      const xMultiplier = isMobile ? 55 : 85; 
      const rotateMultiplier = isMobile ? -40 : -45;
      const divisor = isMobile ? 1.5 : 2.0;

      wrappers.forEach(wrapper => {
        const rect = wrapper.getBoundingClientRect();
        const wrapperCenterX = rect.left + rect.width / 2;
        const dist = wrapperCenterX - centerX;
        
        if (Math.abs(dist) < minDistance) {
          minDistance = Math.abs(dist);
          activeIndex = parseInt(wrapper.getAttribute('data-idx') || '0');
        }
        
        const norm = dist / (window.innerWidth / divisor); 
        
        const rotateY = norm * rotateMultiplier; 
        const translateZ = (Math.abs(norm) * zMultiplier) + zOffset; 
        const translateX = norm * xMultiplier; 
        
        const inner3D = wrapper.querySelector('.cinta-3d-item');
        if (inner3D) {
          inner3D.style.transform = `translate3d(${translateX}px, 0, ${translateZ}px) rotateY(${rotateY}deg)`;
        }

        const overlay = wrapper.querySelector('.cinta-overlay');
        if (overlay) {
          overlay.style.backgroundColor = `rgba(0, 0, 0, ${Math.abs(norm) * (isMobile ? 0.35 : 0.5)})`;
        }
      });
      
      dots.forEach(dot => {
        const dotIdx = parseInt(dot.getAttribute('data-dot-idx') || '0');
        if (dotIdx === activeIndex) {
          dot.classList.remove('w-2', 'bg-gray-300', 'dark:bg-gray-700');
          dot.classList.add(isMobile ? 'w-6' : 'w-8', 'bg-[#cc4a04]');
        } else {
          dot.classList.remove('w-6', 'w-8', 'bg-[#cc4a04]');
          dot.classList.add('w-2', 'bg-gray-300', 'dark:bg-gray-700');
        }
      });
      
      requestAnimationFrame(update3DCarousel);
    };

    requestAnimationFrame(update3DCarousel);
  });
</script>