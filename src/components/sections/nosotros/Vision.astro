---
interface Props {
  data: {
    etiqueta: string;
    titulo: string;
    objetivos: { id: string; desc: string; }[];
    imagen: string;
  };
}

const { data } = Astro.props;
---

<section class="w-full bg-white transition-all duration-700 py-16 lg:py-0 border-t border-gray-100">
  <div class="max-w-[1920px] mx-auto px-6 sm:px-12 md:px-16 lg:px-24 flex flex-col lg:flex-row items-center gap-12 lg:gap-20 transition-all duration-700">
    
    <div class="w-full lg:w-1/2 flex flex-col items-start text-left">
      <span class="font-mono text-xs sm:text-sm tracking-[0.2em] text-gray-400 uppercase font-bold mb-5">
        {data.etiqueta}
      </span>
      <h2 class="font-display font-extrabold bg-gradient-to-r from-[#173154] to-[#3b82f6] text-transparent bg-clip-text uppercase text-3xl sm:text-4xl md:text-5xl lg:text-[60px] tracking-tight leading-[0.95] pb-1 transition-all duration-700">
        {data.titulo}
      </h2>
      
      <ul class="mt-10 md:mt-12 space-y-6 md:space-y-8 w-full max-w-xl transition-all duration-700">
        {data.objetivos.map(obj => (
          <li class="flex items-start gap-5">
            <span class="font-mono text-xs text-gray-400 font-bold border-t border-cr-orange pt-1 w-7">{obj.id}</span>
            <p class="font-sans text-gray-600 text-sm sm:text-base md:text-lg font-medium leading-relaxed flex-1 transition-all duration-700">
              {obj.desc}
            </p>
          </li>
        ))}
      </ul>

      <a href="/nosotros" class="group mt-12 md:mt-14 bg-white/40 backdrop-blur-md border border-gray-200 hover:border-gray-400 hover:bg-white/80 text-cr-dark font-sans font-bold text-[13px] md:text-[14px] tracking-widest py-3.5 px-10 transition-all duration-300 hover:shadow-md flex items-center justify-center gap-3">
        <span>VER MÁS</span>
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M7 17L17 7M17 7H7m10 0v10"></path>
        </svg>
      </a>

    </div>

    <div class="w-full lg:w-1/2 relative h-[400px] sm:h-[500px] lg:h-[700px] overflow-hidden transform translate-y-12 transition-all duration-1000 ease-out delay-200">
      <div class="absolute inset-0 bg-gradient-to-tr from-cr-dark/30 to-transparent z-10"></div>
      <img src={data.imagen} alt={`Imagen ${data.titulo}`} class="absolute inset-0 w-full h-full object-cover z-0 transition-transform duration-[2000ms] hover:scale-105" />
    </div>

  </div>
</section>