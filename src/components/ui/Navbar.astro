---
import globalData from '../../data/global.json';

const currentPath = Astro.url.pathname;
const logo = globalData?.logo || {};
const cta = globalData?.botonCTA || { texto: "Cotizar Ahora", ruta: "/contacto", gradiente: "naranja" };

// Función para el degradado del fondo del botón
const getBgGradientClass = (tipo?: string) => {
  if (tipo === 'naranja') return 'bg-gradient-to-r from-[#cc4a04] to-[#fb923c]';
  if (tipo === 'azul') return 'bg-gradient-to-r from-[#173154] to-[#3b82f6]'; 
  return 'bg-[#cc4a04]'; 
};
---

<header id="navbar" class="fixed top-0 w-full z-50 transition-all duration-500 ease-in-out bg-transparent border-b border-transparent">
  
  <div id="navbar-container" class="max-w-[1920px] mx-auto h-[88px] flex items-center justify-between px-6 md:px-12 lg:px-24 transition-all duration-500">
    
    <a href="/" class="flex items-center group">
      {logo?.rutaClaro && (
        <img 
          src={logo.rutaClaro} 
          alt="CR Publicidad" 
          class="h-10 md:h-12 w-auto object-contain dark:hidden transition-all duration-500 group-hover:scale-105" 
        />
      )}
      {logo?.rutaOscuro && (
        <img 
          src={logo.rutaOscuro} 
          alt="CR Publicidad" 
          class="h-10 md:h-12 w-auto object-contain hidden dark:block transition-all duration-500 group-hover:scale-105" 
        />
      )}
    </a>

    <nav class="hidden lg:flex items-center gap-10">
      {globalData.navegacion.map((item) => {
        const isActive = currentPath === item.ruta || (currentPath === '/' && item.ruta === '/');
        return (
          <a 
            href={item.ruta} 
            class={`font-sans text-[13px] tracking-[0.1em] font-medium py-2 relative group transition-colors duration-300 uppercase
              ${isActive ? 'text-cr-orange' : 'text-gray-500 dark:text-gray-400 hover:text-cr-orange dark:hover:text-cr-orange'}
            `}
          >
            <span class="relative z-10">{item.nombre}</span>
            <span class={`absolute bottom-0 left-1/2 transform -translate-x-1/2 h-[1.5px] bg-cr-orange transition-all duration-300 ease-out
              ${isActive ? 'w-full' : 'w-0 group-hover:w-full'}
            `}></span>
          </a>
        );
      })}
    </nav>

    <div class="hidden lg:block">
      <a href={cta.ruta} class={`text-white font-sans font-bold text-[13px] tracking-wider py-2.5 px-6 transition-all duration-300 hover:scale-105 inline-block shadow-sm rounded-sm ${getBgGradientClass(cta.gradiente)}`}>
        {cta.texto}
      </a>
    </div>

    <button id="mobile-menu-btn" class="lg:hidden text-cr-dark dark:text-white p-2 focus:outline-none">
      <svg class="w-8 h-8 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
        <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="lg:hidden absolute top-full left-0 w-full bg-white/95 dark:bg-[#050505]/95 backdrop-blur-md border-t border-gray-100 dark:border-gray-900 flex flex-col items-start gap-3 px-8 py-8 shadow-xl transition-all duration-500 origin-top transform scale-y-0 opacity-0 h-0 overflow-hidden">
    {globalData.navegacion.map((item) => {
      const isActive = currentPath === item.ruta || (currentPath === '/' && item.ruta === '/');
      return (
        <a 
          href={item.ruta} 
          class={`w-full font-sans text-sm tracking-widest font-medium pb-4 pt-2 uppercase transition-colors duration-300 border-b border-gray-50 dark:border-gray-900/50
            ${isActive ? 'text-cr-orange' : 'text-gray-600 dark:text-gray-400 hover:text-cr-orange dark:hover:text-cr-orange'}
          `}
        >
          <span class="relative group inline-block">
            <span class="relative z-10">{item.nombre}</span>
            <span class={`absolute -bottom-[2px] left-0 h-[1.5px] bg-cr-orange transition-all duration-300 ease-out
              ${isActive ? 'w-full' : 'w-0 group-hover:w-full'}
            `}></span>
          </span>
        </a>
      );
    })}
    <a href={cta.ruta} class={`text-white font-sans font-bold tracking-widest text-sm py-3 px-6 mt-4 w-full text-center shadow-md transition-colors rounded-sm ${getBgGradientClass(cta.gradiente)}`}>
      {cta.texto}
    </a>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar');
  const navContainer = document.getElementById('navbar-container');
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  let isMenuOpen = false;

  function actualizarNavbar() {
    const currentScrollY = window.scrollY;

    if (isMenuOpen || currentScrollY > 20) {
      navbar?.classList.remove('bg-transparent', 'border-transparent');
      navbar?.classList.add('bg-white/85', 'dark:bg-[#050505]/85', 'backdrop-blur-md', 'border-gray-200', 'dark:border-gray-800', 'shadow-sm');
      
      if (currentScrollY > 20) {
        navContainer?.classList.remove('h-[88px]');
        navContainer?.classList.add('h-[72px]');
      } else {
        navContainer?.classList.remove('h-[72px]');
        navContainer?.classList.add('h-[88px]');
      }
    } 
    else {
      navbar?.classList.add('bg-transparent', 'border-transparent');
      navbar?.classList.remove('bg-white/85', 'dark:bg-[#050505]/85', 'backdrop-blur-md', 'border-gray-200', 'dark:border-gray-800', 'shadow-sm');
      
      navContainer?.classList.remove('h-[72px]');
      navContainer?.classList.add('h-[88px]');
    }
  }

  window.addEventListener('scroll', actualizarNavbar);

  mobileBtn?.addEventListener('click', () => {
    isMenuOpen = !isMenuOpen; 
    actualizarNavbar();

    if (isMenuOpen) {
      mobileMenu?.classList.remove('h-0');
      setTimeout(() => {
        mobileMenu?.classList.remove('scale-y-0', 'opacity-0');
        mobileMenu?.classList.add('scale-y-100', 'opacity-100');
      }, 10);
      hamburgerIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
    } else {
      mobileMenu?.classList.add('scale-y-0', 'opacity-0');
      mobileMenu?.classList.remove('scale-y-100', 'opacity-100');
      setTimeout(() => mobileMenu?.classList.add('h-0'), 300); 
      hamburgerIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    }
  });
</script>