---
import Layout from '../layouts/Layout.astro';
import contactoData from '../data/contacto.json';

const hero = contactoData?.hero || {};
const form = contactoData?.formulario || {};
const campos = form?.campos || {};
const info = contactoData?.info || {};

// Degradado para Textos
const getGradientClass = (tipo?: string) => {
  if (tipo === 'naranja') return 'bg-gradient-to-r from-[#cc4a04] to-[#fb923c] text-transparent bg-clip-text inline-block';
  if (tipo === 'azul') return 'bg-gradient-to-r from-[#173154] to-[#3b82f6] text-transparent bg-clip-text inline-block';
  return 'text-cr-dark dark:text-white inline-block';
};

// Degradado de Fondo para el Botón
const getBgGradientClass = (tipo?: string) => {
  if (tipo === 'naranja') return 'bg-gradient-to-r from-[#cc4a04] to-[#fb923c]';
  if (tipo === 'azul') return 'bg-gradient-to-r from-[#173154] to-[#3b82f6]'; 
  return 'bg-[#cc4a04]'; 
};

// Hover dinámico para las tarjetas
const getHoverTextClass = (tipo?: string) => {
  if (tipo === 'naranja') return 'group-hover:text-[#cc4a04] dark:group-hover:text-[#cc4a04]';
  if (tipo === 'azul') return 'group-hover:text-[#173154] dark:group-hover:text-[#3b82f6]';
  return 'group-hover:text-[#cc4a04]';
};

// Repertorio de Iconos SVG Integrados
const IconosSVG: Record<string, string> = {
  phone: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>`,
  mail: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2" ry="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>`,
  map: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>`,
  clock: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>`,
  facebook: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>`,
  instagram: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>`,
  linkedin: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>`,
  whatsapp: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>`
};

const recaptchaKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY;
---

<Layout title="Contacto | CR Publicidad">
  
  <script src="https://www.google.com/recaptcha/api.js" async defer is:inline></script>

  {Object.keys(hero).length > 0 && (
    <section class="relative w-full pt-[140px] md:pt-[180px] pb-16 md:pb-24 flex items-center justify-center transition-all duration-700 overflow-hidden">
      
      <div class="absolute inset-0 w-full h-full z-0">
        <div class="absolute inset-0 bg-white/85 dark:bg-[#050505]/85 z-10 transition-colors duration-700"></div>
        {hero?.imagenFondo && <img src={hero.imagenFondo} alt="Contacto CR Publicidad" class="absolute inset-0 w-full h-full object-cover z-0 opacity-80 dark:opacity-40" />}
      </div>
      
      <div class="absolute bottom-0 left-0 w-full h-16 md:h-24 bg-gradient-to-t from-white dark:from-[#050505] to-transparent z-10 pointer-events-none transition-colors duration-700"></div>
      
      <div id="hero-contacto-content" class="relative z-20 flex flex-col items-center text-center px-6 max-w-4xl transform translate-y-12 opacity-0 blur-md transition-all duration-1000 ease-out">
        {hero?.etiqueta && (
          <span class="font-mono text-[10px] md:text-[11px] tracking-[0.3em] text-[#cc4a04] uppercase font-bold mb-4">
            {hero.etiqueta}
          </span>
        )}
        
        <h1 class="font-display font-extrabold uppercase leading-[1.05] md:leading-[0.95] flex flex-col items-center transition-all duration-700">
          {hero?.titulos?.map((t: any) => (
            <span class={`text-4xl sm:text-5xl md:text-6xl lg:text-[70px] tracking-tight pb-1 ${getGradientClass(t.gradiente)}`}>
              {t.texto}
            </span>
          ))}
        </h1>
        
        {hero?.descripcion && (
          <p class="font-sans text-gray-600 dark:text-gray-400 mt-6 text-sm md:text-base font-medium max-w-2xl transition-colors duration-700">
            {hero.descripcion}
          </p>
        )}
      </div>
    </section>
  )}

  <section class="relative z-20 w-full bg-white dark:bg-[#050505] pb-24 lg:pb-32 transition-colors duration-700">
    <div class="max-w-[1400px] mx-auto px-6 sm:px-12 lg:px-24 pt-6">
      
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 transition-all duration-700">
        
        <div class="lg:col-span-7 observer-blur opacity-0 translate-y-8 transition-all duration-1000 ease-out bg-white dark:bg-[#0a0a0a] p-8 md:p-12 rounded-sm shadow-sm border border-gray-100 dark:border-gray-900">
          
          <h2 class="font-display font-bold text-3xl md:text-4xl text-cr-dark dark:text-white mb-2">{form?.titulo}</h2>
          <p class="font-sans text-gray-500 dark:text-gray-400 text-sm mb-10">{form?.descripcion}</p>

          <form id="contacto-form" class="flex flex-col gap-6" method="POST" novalidate>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="flex flex-col">
                <label class="font-sans text-[10px] font-bold tracking-widest text-gray-500 dark:text-gray-400 uppercase mb-2">{campos.nombre?.label}</label>
                <input type="text" name="nombre" placeholder={campos.nombre?.placeholder} required class="w-full bg-transparent border border-gray-200 dark:border-gray-800 rounded-sm px-4 py-3 text-sm text-cr-dark dark:text-white focus:outline-none focus:border-[#cc4a04] dark:focus:border-[#cc4a04] transition-colors" />
              </div>
              <div class="flex flex-col">
                <label class="font-sans text-[10px] font-bold tracking-widest text-gray-500 dark:text-gray-400 uppercase mb-2">{campos.email?.label}</label>
                <input type="email" name="email" placeholder={campos.email?.placeholder} required class="w-full bg-transparent border border-gray-200 dark:border-gray-800 rounded-sm px-4 py-3 text-sm text-cr-dark dark:text-white focus:outline-none focus:border-[#cc4a04] dark:focus:border-[#cc4a04] transition-colors" />
              </div>
              <div class="flex flex-col">
                <label class="font-sans text-[10px] font-bold tracking-widest text-gray-500 dark:text-gray-400 uppercase mb-2">{campos.telefono?.label}</label>
                <input type="tel" name="telefono" placeholder={campos.telefono?.placeholder} class="w-full bg-transparent border border-gray-200 dark:border-gray-800 rounded-sm px-4 py-3 text-sm text-cr-dark dark:text-white focus:outline-none focus:border-[#cc4a04] dark:focus:border-[#cc4a04] transition-colors" />
              </div>
              <div class="flex flex-col">
                <label class="font-sans text-[10px] font-bold tracking-widest text-gray-500 dark:text-gray-400 uppercase mb-2">{campos.empresa?.label}</label>
                <input type="text" name="empresa" placeholder={campos.empresa?.placeholder} class="w-full bg-transparent border border-gray-200 dark:border-gray-800 rounded-sm px-4 py-3 text-sm text-cr-dark dark:text-white focus:outline-none focus:border-[#cc4a04] dark:focus:border-[#cc4a04] transition-colors" />
              </div>
            </div>

            <div class="flex flex-col">
              <label class="font-sans text-[10px] font-bold tracking-widest text-gray-500 dark:text-gray-400 uppercase mb-2">{campos.servicio?.label}</label>
              <div class="relative">
                <select name="servicio" class="w-full bg-transparent border border-gray-200 dark:border-gray-800 rounded-sm px-4 py-3 text-sm text-gray-500 dark:text-gray-400 focus:outline-none focus:border-[#cc4a04] dark:focus:border-[#cc4a04] transition-colors appearance-none cursor-pointer">
                  <option value="" disabled selected>{campos.servicio?.placeholder}</option>
                  {campos.servicio?.opciones?.map((opcion: string) => (
                    <option value={opcion}>{opcion}</option>
                  ))}
                </select>
                <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-400">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                </div>
              </div>
            </div>

            <div class="flex flex-col relative">
              <label class="font-sans text-[10px] font-bold tracking-widest text-gray-500 dark:text-gray-400 uppercase mb-2">{campos.mensaje?.label}</label>
              <textarea id="mensaje-input" name="mensaje" placeholder={campos.mensaje?.placeholder} required maxlength="500" class="w-full bg-transparent border border-gray-200 dark:border-gray-800 rounded-sm px-4 py-3 text-sm text-cr-dark dark:text-white focus:outline-none focus:border-[#cc4a04] dark:focus:border-[#cc4a04] transition-colors resize-none h-32"></textarea>
              <span id="char-counter" class="absolute bottom-[-20px] right-0 text-[10px] text-gray-400 font-mono">0/500</span>
            </div>

            {recaptchaKey && (
              <div class="w-full flex justify-start mt-2">
                <div class="g-recaptcha" data-sitekey={recaptchaKey}></div>
              </div>
            )}

            <button type="submit" class={`w-full group text-white font-sans font-bold text-xs md:text-[13px] tracking-widest py-4 mt-2 transition-all duration-300 hover:scale-[1.02] shadow-md flex items-center justify-center gap-3 rounded-sm ${getBgGradientClass(form?.boton?.gradiente)}`}>
              <span>{form?.boton?.texto}</span>
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1 group-hover:-translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"></path><path d="M22 2l-7 20-4-9-9-4 20-7z"></path></svg>
            </button>
            
          </form>
        </div>

        <div class="lg:col-span-5 flex flex-col gap-6 observer-blur opacity-0 translate-y-8 transition-all duration-1000 ease-out delay-200">
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-6">
            {info?.tarjetas?.map((tarjeta: any) => {
              const iconColorBg = tarjeta.color === 'naranja' ? 'bg-[#cc4a04]/10 text-[#cc4a04]' : 'bg-[#173154]/10 text-[#173154] dark:bg-[#3b82f6]/10 dark:text-[#3b82f6]';
              
              return (
                <div class="group bg-white dark:bg-[#0a0a0a] border border-gray-100 dark:border-gray-900 p-6 rounded-sm shadow-sm flex flex-col transition-all duration-500 hover:-translate-y-1 hover:shadow-md cursor-default">
                  <div class={`w-10 h-10 flex items-center justify-center rounded-sm mb-4 transition-colors duration-500 ${iconColorBg}`} set:html={IconosSVG[tarjeta.icono]}>
                  </div>
                  <h3 class={`font-display font-bold text-cr-dark dark:text-white text-sm mb-2 transition-colors duration-300 ${getHoverTextClass(tarjeta.color)}`}>{tarjeta.titulo}</h3>
                  <div class="flex flex-col gap-1">
                    {tarjeta.lineas.map((linea: string) => (
                      <span class={`font-sans text-xs text-gray-500 dark:text-gray-400 leading-relaxed transition-colors duration-300 ${getHoverTextClass(tarjeta.color)}`}>{linea}</span>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>

          {info?.mapa?.iframeUrl && (
            <div class="w-full h-64 md:h-[320px] bg-gray-200 dark:bg-gray-800 border border-gray-100 dark:border-gray-900 rounded-sm overflow-hidden shadow-sm relative group">
              <iframe 
                src={info.mapa.iframeUrl} 
                width="100%" 
                height="100%" 
                style="border:0;" 
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade"
                class="absolute inset-0 w-full h-full grayscale opacity-70 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 z-0"
              ></iframe>
              <div class="absolute inset-0 z-10 pointer-events-none border border-transparent group-hover:border-[#cc4a04]/50 transition-colors duration-700"></div>
            </div>
          )}

          {info?.redes && (
            <div class="flex items-center gap-4 mt-auto pt-4 border-t border-gray-200 dark:border-gray-800">
              <span class="font-sans text-[10px] font-bold tracking-widest text-gray-400 uppercase mr-2">{info.redes.etiqueta}</span>
              {info.redes.items.map((red: any) => (
                <a href={red.url} target="_blank" rel="noopener noreferrer" class="w-8 h-8 flex items-center justify-center border border-gray-200 dark:border-gray-800 rounded-sm text-gray-400 hover:text-[#cc4a04] dark:hover:text-[#cc4a04] hover:border-[#cc4a04] transition-all duration-300 hover:-translate-y-1" aria-label={red.nombre} set:html={IconosSVG[red.icono]}>
                </a>
              ))}
            </div>
          )}

        </div>

      </div>
    </div>
  </section>

  <div id="custom-modal" class="fixed inset-0 z-[100] hidden items-center justify-center opacity-0 transition-opacity duration-300">
    
    <div id="modal-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm cursor-pointer transition-opacity duration-300"></div>
    
    <div id="modal-box" class="relative bg-white dark:bg-[#0a0a0a] border border-gray-200 dark:border-gray-800 p-8 md:p-10 rounded-sm shadow-2xl max-w-sm w-[90%] transform scale-95 transition-transform duration-300 z-10 flex flex-col items-center text-center">
      
      <div class="w-16 h-16 rounded-sm flex items-center justify-center mb-6 shadow-inner bg-[#cc4a04]/10 text-[#cc4a04]">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
        </svg>
      </div>
      
      <h3 id="modal-title" class="font-display font-extrabold text-2xl md:text-3xl text-cr-dark dark:text-white mb-3 uppercase tracking-tight leading-none">
        Acción Requerida
      </h3>
      
      <p id="modal-message" class="font-sans text-gray-600 dark:text-gray-400 text-sm md:text-base leading-relaxed mb-8">
        Mensaje de error predeterminado.
      </p>
      
      <button id="modal-close-btn" class="w-full bg-gradient-to-r from-[#cc4a04] to-[#fb923c] text-white font-sans font-bold text-[13px] tracking-widest uppercase py-3.5 rounded-sm shadow-lg shadow-orange-500/30 hover:-translate-y-0.5 transition-all duration-300">
        Entendido
      </button>
      
    </div>
  </div>

</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    
    // --- LÓGICA DE ANIMACIÓN INICIAL ---
    const initContacto = () => {
      // Nota: También quitamos el 'blur-md' del nuevo Hero
      document.getElementById('hero-contacto-content')?.classList.remove('translate-y-12', 'opacity-0', 'blur-md');
      document.querySelectorAll('.observer-blur').forEach(el => el.classList.remove('opacity-0', 'translate-y-8'));
    };

    if (sessionStorage.getItem('preloaderVisto')) {
      setTimeout(initContacto, 50);
    } else {
      document.addEventListener('preloaderTerminado', initContacto);
      setTimeout(initContacto, 3000); 
    }

    // --- CONTADOR DE CARACTERES ---
    const mensajeInput = document.getElementById('mensaje-input') as HTMLTextAreaElement;
    const charCounter = document.getElementById('char-counter');
    
    if (mensajeInput && charCounter) {
      mensajeInput.addEventListener('input', () => {
        const length = mensajeInput.value.length;
        charCounter.textContent = `${length}/500`;
        if (length >= 500) {
          charCounter.classList.add('text-red-500');
          charCounter.classList.remove('text-gray-400');
        } else {
          charCounter.classList.remove('text-red-500');
          charCounter.classList.add('text-gray-400');
        }
      });
    }

    // --- LÓGICA DEL MODAL ---
    const modal = document.getElementById('custom-modal');
    const modalBox = document.getElementById('modal-box');
    const backdrop = document.getElementById('modal-backdrop');
    const closeBtn = document.getElementById('modal-close-btn');
    const titleEl = document.getElementById('modal-title');
    const messageEl = document.getElementById('modal-message');

    const openModal = (title: string, message: string) => {
      if (!modal || !modalBox) return;
      if (titleEl && title) titleEl.textContent = title;
      if (messageEl && message) messageEl.textContent = message;

      modal.classList.remove('hidden');
      modal.classList.add('flex');
      
      setTimeout(() => {
        modal.classList.remove('opacity-0');
        modalBox.classList.remove('scale-95');
        modalBox.classList.add('scale-100');
      }, 10);
    };

    const closeModal = () => {
      if (!modal || !modalBox) return;
      
      modal.classList.add('opacity-0');
      modalBox.classList.remove('scale-100');
      modalBox.classList.add('scale-95');
      
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }, 300);
    };

    if (backdrop) backdrop.addEventListener('click', closeModal);
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
        closeModal();
      }
    });

    // --- INTERCEPTAR FORMULARIO CON VALIDACIÓN COMPLETA ---
    const form = document.getElementById('contacto-form') as HTMLFormElement;
    
    form?.addEventListener('submit', (e) => {
      e.preventDefault(); 
      
      const nombre = (form.elements.namedItem('nombre') as HTMLInputElement)?.value.trim();
      const email = (form.elements.namedItem('email') as HTMLInputElement)?.value.trim();
      const mensaje = (form.elements.namedItem('mensaje') as HTMLTextAreaElement)?.value.trim();
      const recaptchaResponse = (document.querySelector('.g-recaptcha-response') as HTMLTextAreaElement)?.value;
      
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      if (!nombre) {
        return openModal('Falta tu Nombre', 'Por favor, ingresa tu nombre para saber con quién nos comunicamos.');
      }

      if (!email) {
        return openModal('Falta tu Correo', 'Por favor, ingresa un correo electrónico de contacto.');
      } else if (!emailRegex.test(email)) {
        return openModal('Correo Inválido', 'Por favor, asegúrate de escribir tu correo correctamente.');
      }

      if (!mensaje) {
        return openModal('Mensaje Vacío', 'Por favor, escríbenos qué necesitas antes de enviar el formulario.');
      }

      if (document.querySelector('.g-recaptcha') && !recaptchaResponse) {
        return openModal('Acción Requerida', 'Por favor, confirma que no eres un robot marcando la casilla de verificación.');
      }
      
      // Si todo está correcto, se envía el formulario de verdad.
      form.submit();
    });

  });
</script>