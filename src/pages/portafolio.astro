---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/ui/CTA.astro';
//import Categorias from '../components/Categorias.astro';
import PortfolioItem from '../components/PortfolioItem.astro';
import ProjectModal from '../components/ProjectModal.astro';
import portafolioData from '../data/portafolio.json';

const hero = portafolioData.hero;
const categorias = portafolioData.categorias;
const trabajos = portafolioData.trabajos;

const getGradientClass = (tipo?: string) => {
  if (tipo === 'azul') return 'bg-gradient-to-r from-[#173154] to-[#3b82f6] text-transparent bg-clip-text inline-block';
  if (tipo === 'naranja') return 'bg-gradient-to-r from-[#cc4a04] to-[#fb923c] text-transparent bg-clip-text inline-block';
  return 'text-cr-dark dark:text-white inline-block';
};
---

<Layout title="Portafolio | CR Publicidad">

  <section class="relative w-full pt-[140px] md:pt-[180px] pb-16 md:pb-24 flex items-center justify-center transition-all duration-700 overflow-hidden">
    <div class="absolute inset-0 w-full h-full z-0">
      <div class="absolute inset-0 bg-white/85 dark:bg-[#050505]/85 z-10 transition-colors duration-700"></div>
      {hero?.imagenFondo && (
        <img 
          src={hero.imagenFondo} 
          alt="Portafolio" 
          class="animate-hero-pan absolute inset-0 w-full h-full object-cover z-0 opacity-80 dark:opacity-40" 
        />
      )}
    </div>
    <div class="absolute bottom-0 left-0 w-full h-16 md:h-24 bg-gradient-to-t from-white dark:from-[#050505] to-transparent z-10 pointer-events-none transition-colors duration-700"></div>
    
    <div id="hero-portafolio-content" class="relative z-20 flex flex-col items-center text-center px-6 max-w-4xl transform translate-y-12 opacity-0 blur-md transition-all duration-1000 ease-out">
      {hero?.etiqueta && <span class="font-mono text-[10px] md:text-[11px] tracking-[0.3em] text-[#cc4a04] uppercase font-bold mb-4">{hero.etiqueta}</span>}
      <h1 class="font-display font-extrabold uppercase leading-[1.05] md:leading-[0.95] flex flex-col items-center">
        {hero?.titulos?.map((t: any) => <span class={`text-4xl sm:text-5xl md:text-6xl lg:text-[70px] tracking-tight pb-1 ${getGradientClass(t.gradiente)}`}>{t.texto}</span>)}
      </h1>
      {hero?.descripcion && <p class="font-sans text-gray-600 dark:text-gray-400 mt-6 text-sm md:text-base font-medium max-w-2xl">{hero.descripcion}</p>}
    </div>
  </section>

  <section class="w-full bg-white dark:bg-[#050505] pb-24 transition-colors duration-700 relative">
    <div class="w-full max-w-[1200px] mx-auto px-6 lg:px-8 observer-blur transform translate-y-12 opacity-0 blur-md transition-all duration-[1000ms] ease-out pt-6 md:pt-10">
      
      

      <div id="portfolio-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6 auto-rows-[200px] md:auto-rows-[260px] transition-all duration-700">
        {trabajos.map((trabajo: any, index: number) => (
          <div style={`animation-delay: ${index * 80}ms;`} class="contents">
            <PortfolioItem trabajo={trabajo} /> 
          </div>
        ))}
      </div>

    </div>
  </section>

  <CTA id="cta-final-contacto" />
  
  <ProjectModal />

</Layout>

<style is:global>

/* Efecto de Paneo Suave para el Hero */
  .animate-hero-pan {
    /* 40 segundos hace que sea ultra lento, ease-in-out hace que frene suave al llegar a los bordes */
    animation: heroPan 40s ease-in-out infinite;
    /* Optimiza el rendimiento para que no consuma CPU ni se vea con tirones */
    will-change: transform; 
  }

  @keyframes heroPan {
    0% { transform: scale(1.15) translateX(2.5%); }
    50% { transform: scale(1.15) translateX(-2.5%); }
    100% { transform: scale(1.15) translateX(2.5%); }
  }

  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  /* BARRITA DE SCROLL  CORPORATIVA DEL MODAL */
  .custom-scrollbar::-webkit-scrollbar { width: 6px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background-color: rgba(204, 74, 4, 0.4);
    border-radius: 10px;
  }
  .dark .custom-scrollbar::-webkit-scrollbar-thumb { background-color: rgba(255, 255, 255, 0.2); }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background-color: #cc4a04; }

  /* ESTADOS ACTIVOS DE LA BARRA (Prioridad máxima) */
  .active { 
    background: transparent !important; 
    color: white !important; 
    position: relative;
  }
  
  .active.active-naranja { background: linear-gradient(135deg, #cc4a04, #fb923c) !important; }
  .active.active-azul { background: linear-gradient(135deg, #173154, #3b82f6) !important; }

  /* Aseguramos que el texto dentro del botón activo siempre sea blanco */
  .filter-btn.active span { 
    color: white !important; 
    font-weight: 800; 
  }

  /* Etiquetas de servicios */
  .tag-azul { background: linear-gradient(to right, #173154, #3b82f6); color: white; }
  .tag-naranja { background: linear-gradient(to right, #cc4a04, #fb923c); color: white; }

  /* BOTONES DE REDES SOCIALES */
  .social-btn {
    display: inline-flex; align-items: center; gap: 0.5rem; color: white;
    padding: 0.5rem 1rem; border-radius: 0.125rem; font-family: ui-sans-serif, system-ui;
    font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;
    transition: all 0.3s ease;
  }
  .social-btn:hover { transform: translateY(-3px); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.3); }
  
  .social-instagram { background: linear-gradient(to top right, #f9ce34, #ee2a7b, #6228d7); }
  .social-facebook { background: #1877F2; }
  .social-tiktok { background: #000000; }
  .dark .social-tiktok { background: #333333; }
  .social-youtube { background: #FF0000; }
  .social-whatsapp { background: #25D366; }

</style>

<script>
  const SocialIcons: any = {
    instagram: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>`,
    facebook: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
    tiktok: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 2.22-1.15 4.35-2.95 5.6-1.8 1.26-4.14 1.58-6.17.95-2.02-.62-3.6-2.04-4.38-3.95-.78-1.9-.59-4.15.53-5.88 1.11-1.74 3.02-2.84 5.06-2.94v4.02c-1.13.08-2.18.73-2.73 1.71-.56.97-.52 2.22.09 3.16.6.95 1.73 1.45 2.82 1.33 1.09-.12 2.02-.85 2.4-1.86.19-.51.27-1.07.26-1.62v-17.3Z"/></svg>`,
    youtube: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
    whatsapp: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>`
  };

  document.addEventListener('DOMContentLoaded', () => {
    
    // 1. Arranque
    setTimeout(() => {
      const hero = document.getElementById('hero-portafolio-content');
      if (hero) hero.classList.remove('translate-y-12', 'opacity-0', 'blur-md');
      document.querySelectorAll('.observer-blur').forEach(el => el.classList.remove('opacity-0', 'translate-y-12', 'blur-md'));
    }, 100);

    // 2. Filtros de Categorías (CORREGIDO PARA PORTAFOLIO)
    const filterBtns = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.portfolio-item');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        const f = target.dataset.filter;
        const c = target.dataset.color || 'naranja';

        // A. Limpiar todos los botones
        filterBtns.forEach(b => {
          b.classList.remove('active', 'active-naranja', 'active-azul');
          b.classList.add('text-gray-500', 'dark:text-gray-400');
        });

        // B. Activar botones correspondientes (Móvil y Desktop)
        document.querySelectorAll(`.filter-btn[data-filter="${f}"]`).forEach(b => {
          b.classList.add('active', `active-${c}`);
          b.classList.remove('text-gray-500', 'dark:text-gray-400');
        });

        // C. Filtrar los items de la grilla
        items.forEach((item: any) => {
          if (f === 'todas' || item.dataset.category === f) {
            item.classList.remove('hidden');
            setTimeout(() => item.style.opacity = '1', 10);
          } else {
            item.style.opacity = '0';
            setTimeout(() => item.classList.add('hidden'), 300);
          }
        });
      });
    });

    // 3. Orquestador del Modal
    const modal = document.getElementById('project-modal');
    const modalBox = document.getElementById('modal-box');
    const mainImg = document.getElementById('modal-main-img') as HTMLImageElement;
    const thumbsCont = document.getElementById('modal-thumbs-container');
    let timerId: number;
    let currentGallery: string[] = [];
    let currentIdx = 0;

    const changeImage = (idx: number) => {
      if (!mainImg || !currentGallery[idx]) return;
      currentIdx = idx;
      
      mainImg.style.opacity = '0.4';
      setTimeout(() => {
        mainImg.src = currentGallery[idx];
        mainImg.style.opacity = '1';
      }, 200);

      // Resaltar miniatura activa
      const thumbs = thumbsCont?.querySelectorAll('.thumb-btn');
      if (thumbs) {
        thumbs.forEach((t, i) => {
          if (i === idx) t.classList.add('border-[#cc4a04]');
          else t.classList.remove('border-[#cc4a04]');
        });
      }
    };

    const startTimer = () => {
      clearInterval(timerId);
      timerId = window.setInterval(() => {
        let next = (currentIdx + 1) % currentGallery.length;
        changePhotoManual(next);
      }, 4000);
    };

    const changePhotoManual = (idx: number) => {
      changeImage(idx);
      startTimer();
    };

    const openModal = (jsonString: string) => {
      const data = JSON.parse(jsonString);
      
      currentGallery = data.galeria && data.galeria.length > 0 ? data.galeria : [data.imagenPrincipal];
      currentIdx = 0;

      // Textos Básicos
      const elTitle = document.getElementById('modal-title');
      if (elTitle) elTitle.textContent = data.titulo;
      
      const elLoc = document.getElementById('modal-location');
      if (elLoc) elLoc.textContent = data.ubicacion;
      
      const elClient = document.getElementById('modal-client');
      if (elClient) elClient.textContent = `Cliente: ${data.cliente}`;
      
      const elYear = document.getElementById('modal-year');
      if (elYear) elYear.textContent = `Año: ${data.anio}`;
      
      const elDesc = document.getElementById('modal-description');
      if (elDesc) elDesc.textContent = data.descripcion;

      const catName = document.querySelector(`.filter-btn[data-filter="${data.categoriaId}"] span`)?.textContent;
      const elCat = document.getElementById('modal-category');
      if (elCat) elCat.textContent = catName || "Proyecto";

      // Renderizar Miniaturas (Thumbnails)
      if (thumbsCont) {
        thumbsCont.innerHTML = currentGallery.map((img: string, i: number) => `
          <button class="thumb-btn border-t-4 border-transparent aspect-video bg-[#111] overflow-hidden relative group transition-all duration-300" data-idx="${i}">
            <div class="absolute inset-0 bg-black/40 group-hover:bg-transparent transition-colors z-10"></div>
            <img src="${img}" class="w-full h-full object-cover" />
          </button>
        `).join('');

        thumbsCont.querySelectorAll('.thumb-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const idx = parseInt((e.currentTarget as HTMLElement).getAttribute('data-idx') || '0');
            changePhotoManual(idx);
          });
        });
      }

      // Cargar primera imagen y arrancar reloj
      changeImage(0);
      startTimer();

      // Tags de Servicios
      const tagsCont = document.getElementById('modal-services-tags');
      if (tagsCont) {
        tagsCont.innerHTML = data.servicios.map((s: any) => {
          const colorClass = s.color === 'azul' ? 'tag-azul' : 'tag-naranja';
          return `<span class="${colorClass} px-3 py-1.5 rounded-sm text-[10px] md:text-xs font-bold uppercase tracking-widest transition-transform hover:-translate-y-0.5">${s.texto}</span>`;
        }).join('');
      }

      // Redes Sociales
      const socCont = document.getElementById('modal-socials-container');
      const socBtns = document.getElementById('modal-social-buttons');
      if (data.redes && Object.keys(data.redes).length > 0) {
        if (socCont) socCont.classList.remove('hidden');
        if (socBtns) {
          socBtns.innerHTML = Object.entries(data.redes).map(([name, url]) => {
            const icon = SocialIcons[name.toLowerCase()] || '';
            return `<a href="${url as string}" target="_blank" class="social-btn social-${name.toLowerCase()}">${icon} ${name}</a>`;
          }).join('');
        }
      } else {
        if (socCont) socCont.classList.add('hidden');
      }

      // Mostrar Modal
      document.body.style.overflow = 'hidden';
      if (modal) {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        setTimeout(() => {
          modal.style.opacity = '1';
          if (modalBox) {
            modalBox.style.transform = 'scale(1)';
            modalBox.scrollTop = 0; 
          }
        }, 10);
      }
    };

    const closeModal = () => {
      if (modal) modal.style.opacity = '0';
      if (modalBox) modalBox.style.transform = 'scale(0.95)';
      document.body.style.overflow = '';
      clearInterval(timerId);
      setTimeout(() => {
        if (modal) {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
        }
      }, 300);
    };

    // Asignar Eventos Clic en la grilla
    document.querySelectorAll('.portfolio-item').forEach(item => {
      item.addEventListener('click', (e) => openModal((e.currentTarget as HTMLElement).getAttribute('data-json')!));
    });

    const btnClose = document.getElementById('modal-close-btn');
    if (btnClose) btnClose.addEventListener('click', closeModal);

    const backdropObj = document.getElementById('modal-backdrop');
    if (backdropObj) backdropObj.addEventListener('click', closeModal);

    document.addEventListener('keydown', (e) => { 
      if (e.key === 'Escape') closeModal(); 
    });

    // 4. AUTO-ABRIR MODAL (Desde el Inicio / Marquee)
    const urlParams = new URLSearchParams(window.location.search);
    const proyectoId = urlParams.get('proyecto');
    if (proyectoId) {
      const tarjetaObjetivo = document.querySelector(`.portfolio-item[data-json*='"id":"${proyectoId}"']`);
      if (tarjetaObjetivo) {
        const jsonString = tarjetaObjetivo.getAttribute('data-json');
        setTimeout(() => {
          openModal(jsonString!);
          window.history.replaceState({}, document.title, window.location.pathname);
        }, 300);
      }
    }

  });
</script>